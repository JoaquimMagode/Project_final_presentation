{
  "name": "imap-solution-backend",
  "version": "1.0.0",
  "description": "Backend API for IMAP Solution Medical Tourism Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "create-db": "node create-db.js",
    "seed": "node seed.js",
    "setup-db": "node setup-database.js",
    "migrate": "node migrate-to-hospital-appointments.js",
    "reset-db": "node reset-db.js",
    "prisma:pull": "prisma db pull --schema=prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "test": "jest"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "nodemailer": "^6.9.4",
    "prisma": "^7.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.6.4",
    "nodemon": "^3.0.1"
  },
  "keywords": [
